# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 数据库配置
# PostgreSQL
DB_URI=postgresql://postgres:password@127.0.0.1:55432/smart_query?client_encoding=utf8
# SQLite (开发/演示)
# DB_URI=sqlite:///./data/ecommerce.db

# ChromaDB 配置
CHROMA_HOST=localhost
CHROMA_PORT=8000

# 应用配置
LOG_LEVEL=INFO
MAX_RETRIES=3
QUERY_TIMEOUT=10
